&НаКлиенте
Процедура ТаблицаВложенийВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	СформироватьПФ();
	ТД = Элементы.ТаблицаВложений.ТекущиеДанные;
	Если ТД = Неопределено Тогда Возврат; КонецЕсли; //Ну нет у нас печатных форм для документа
	ОтобразитьПФ(ТД.ПФ);
КонецПроцедуры

