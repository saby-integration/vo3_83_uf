&НаСервере
Процедура ЗполонитьТабличуПолучателей()
	
	ТаблицаПолучателей.Очистить();
	Для Каждого ДокументКОтправке Из ДокументыКОтправке Цикл
		ДокНаПодпись = ДокументКОтправке.Документ;
		//Есть 2 варианда получения Руководителя
		////И так
		//Подписанты = Новый Структура("Организация,Руководитель", ДокНаПодпись.Организация);
		//ЗарплатаКадры.ПолучитьЗначенияПоУмолчанию(Подписанты, ТекущаяДата());
		//Руководитель = Подписанты.Руководитель;
		//И так
		Подписанты = ЗарплатаКадры.ОтветственныеЛицаОрганизации(ДокНаПодпись.Организация, "Руководитель, ДолжностьРуководителя", ТекущаяДата());
		Руководитель = Подписанты.Руководитель;
		
		НовыйПодписант = ТаблицаПолучателей.Добавить();
		НовыйПодписант.Подписант	= Руководитель;
		НовыйПодписант.Документ		= ДокНаПодпись;
		НовыйПодписант = ТаблицаПолучателей.Добавить();
		НовыйПодписант.Подписант	= ДокНаПодпись.Сотрудник.ФизическоеЛицо;
		НовыйПодписант.Документ		= ДокНаПодпись;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменениеВидаЭлементов()
	Если ПростойЗапрос Тогда
		Элементы.Saby_Комментарий.МногострочныйРежим = Ложь;
		Элементы.ТаблицаПолучателей.Видимость	= Истина;
		ЗполонитьТабличуПолучателей();
	Иначе
		Элементы.Saby_Комментарий.МногострочныйРежим = Истина;
		Элементы.ТаблицаПолучателей.Видимость	= Ложь;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПростойЗапросПриИзменении(Элемент)
	ИзменениеВидаЭлементов();
КонецПроцедуры

&НаКлиенте
Процедура УстановитьФильтрПФПоТипуДокумента(ВидДокумента)
	ТаблицаВложений.Очистить();
	Отбор = Новый Структура;
    Отбор.Вставить("ВидДокумента", ВидДокумента);
    СтрокиПФ = ТаблицаВложенийДанные.НайтиСтроки(Отбор);
	Для Каждого СтрокаДокПФ Из СтрокиПФ Цикл
		ЗаполнитьЗначенияСвойств(ТаблицаВложений.Добавить(), СтрокаДокПФ);
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ДокументыКОтправкеПриАктивизацииСтроки(Элемент)
	ТД = Элементы.ДокументыКОтправке.ТекущиеДанные;
	ТаблицаВложений.Очистить();
	Если ТД = Неопределено ТОгда
		Возврат;
	КонецЕсли;
	УстановитьФильтрПФПоТипуДокумента(ТД.ВидДокумента);
	ПрочитатьВыборПФДляВидаДокумента(ТД.ВидДокумента);
КонецПроцедуры

